{
  "变量声明": { "prefix": "令", "body": ["令 ${1:名称}${2:：任意} 为 ${3:值}；"], "description": "声明言序变量" },
  "不可改写绑定": { "prefix": "定", "body": ["定 ${1:名称}${2:：任意} 为 ${3:值}；"], "description": "声明不可改写绑定" },
  "输出": { "prefix": "言", "body": ["言 ${1:值}；"], "description": "输出一个值" },
  "判断": { "prefix": "若", "body": ["若 ${1:条件} 则", "    ${2}", "否则", "    ${3}", "终"], "description": "若/否则判断" },
  "循环": { "prefix": "当", "body": ["当 ${1:条件} 则", "    ${2}", "终"], "description": "当循环" },
  "迭代": { "prefix": "逐", "body": ["逐 ${1:项目}${2:：任意} 于 ${3:容器} 则", "    ${4}", "终"], "description": "迭代列、元组、文字或典" },
  "元组": { "prefix": "元", "body": ["（${1:甲}，${2:乙}）"], "description": "创建不可变元组" },
  "切片": { "prefix": "切片", "body": ["${1:容器}【${2:起}：${3:止}】"], "description": "取得列、元组或文字的半开切片" },
  "捕获错误": { "prefix": "试", "body": ["试 则", "    ${1}", "救 ${2:所误} 则", "    ${3}", "终"], "description": "捕获结构化运行错误" },
  "函数": { "prefix": "法", "body": ["法 ${1:名称}（${2:参数：任意}）${3:：任意} 则", "    ${4}", "终"], "description": "定义函数" },
  "异步函数": { "prefix": "异法", "body": ["异 法 ${1:名称}（${2:参数：任意}）${3:：任意} 则", "    ${4}", "终"], "description": "定义返回任务的异步函数" },
  "等待任务": { "prefix": "候", "body": ["候 ${1:任务}"], "description": "等待任务并取得其结果" },
  "结构化等待": { "prefix": "并候", "body": ["并候（【${1:任务甲}，${2:任务乙}】）"], "description": "在结构化作用域等待一组任务" },
  "类": { "prefix": "类", "body": ["类 ${1:名称} 则", "    公 域 ${2:字段}：${3:任意}；", "    法 初始化（${2:字段}：${3:任意}）则", "        置 此.${2:字段} 为 ${2:字段}；", "    终", "$0", "终"], "description": "定义类、字段与初始化方法" },
  "结构协议": { "prefix": "协", "body": ["协 ${1:名称} 则", "    域 ${2:字段}：${3:任意}；", "    法 ${4:方法}（${5}）：${6:任意}；", "终"], "description": "定义结构协议" },
  "纳入协议": { "prefix": "纳", "body": ["类 ${1:名称} 纳 ${2:协议} 则", "    ${3}", "终"], "description": "定义显式纳入协议的类" },
  "声明字段": { "prefix": "域", "body": ["${1:公} ${2:只} 域 ${3:名称}：${4:任意}${5: 为 值}；"], "description": "声明实例或静态字段" },
  "公开函数": { "prefix": "公法", "body": ["公 法 ${1:名称}（${2:参数：任意}）${3:：任意} 则", "    ${4}", "终"], "description": "定义模块公开函数" },
  "继承类": { "prefix": "承", "body": ["类 ${1:子类} 承 ${2:父类} 则", "    法 初始化（${3:参数：任意}）则", "        父.初始化（${4:参数}）；", "    终", "", "    法 ${5:方法}（）：${6:任意} 则", "        归 父.${5:方法}（）；", "    终", "终"], "description": "定义子类并调用父类初始化法或覆写实现" },
  "调用父类方法": { "prefix": "父", "body": ["父.${1:方法}（${2}）"], "description": "在实例法中调用当前定义类的直接父类实现" },
  "类型判断": { "prefix": "是", "body": ["若 ${1:值} 是 ${2:类型} 则", "    ${3}", "终"], "description": "按运行时类型判断并收窄简单变量" },
  "联合类型": { "prefix": "联合", "body": ["${1:数}|${2:文}"], "description": "创建联合类型标注" },
  "可空类型": { "prefix": "可空", "body": ["${1:数}?"], "description": "创建可空类型标注" },
  "泛型列表": { "prefix": "列型", "body": ["列<${1:数}>"], "description": "创建带元素类型的列标注" },
  "泛型字典": { "prefix": "典型", "body": ["典<${1:文}，${2:数}>"], "description": "创建带键值类型的典标注" },
  "任务类型": { "prefix": "任务型", "body": ["任务<${1:数}>"], "description": "创建任务结果类型标注" },
  "导入模块": { "prefix": "引", "body": ["引「${1:路径.yx}」为 ${2:模块名}；"], "description": "导入文件模块" },
  "导入标准库": { "prefix": "引标准", "body": ["引「标准:${1|文字,数学,时间,文件,JSON,网络,测试,路径,环境,哈希,编码,统计,CSV,随机,标识,模板,校验,Base64,正则,URL,日期,套接字,字节|}」为 ${2:模块}；"], "description": "从 23 个标准模块中选择并导入" },
  "Base64往返": { "prefix": "Base64", "body": ["引「标准:Base64」为 Base64；", "定 编码值：文 为 Base64.编码（${1:原文}）；", "定 原文：文 为 Base64.解码（编码值）；"], "description": "使用言序 1.1 Base64 模块编解码 UTF-8 文字" },
  "正则匹配": { "prefix": "正则", "body": ["引「标准:正则」为 正则；", "定 匹配项：文? 为 正则.首项（「${1:[0-9]+}」，${2:文字}）；"], "description": "使用言序 1.1 正则模块查找首个匹配项" },
  "URL解析": { "prefix": "URL", "body": ["引「标准:URL」为 URL；", "定 主机：文? 为 URL.主机（${1:地址}）；", "定 路径：文 为 URL.路径（${1:地址}）；"], "description": "使用言序 1.1 URL 模块解析地址" },
  "日期运算": { "prefix": "日期", "body": ["引「标准:日期」为 日期；", "定 新日期：文 为 日期.加天（「${1:2026-07-14}」，${2:30}）；"], "description": "使用言序 1.1 日期模块进行确定性公历运算" },
  "网络请求": { "prefix": "网络请求", "body": ["引「标准:网络」为 网络；", "定 响应：典<文，任意> 为 网络.请求（「${1:GET}」，「${2:https://example.com}」，「${3}」，${4:10000}，${5:4194304}）；", "言 响应【「状态」】；", "言 响应【「正文」】；"], "description": "发起带全程超时和响应大小上限的 HTTP/HTTPS 请求" },
  "网络错误": { "prefix": "网络错误", "body": ["试 则", "    ${1:网络.获取（地址）；}", "救 ${2:所误} 则", "    言 ${2:所误}.代码；", "    言 ${2:所误}.类别；", "    言 ${2:所误}.消息；", "终"], "description": "捕获并判断稳定 NET_* 网络错误" },
  "TCP套接字": { "prefix": "TCP套接字", "body": ["引「标准:套接字」为 套接字；", "定 流：套接字 为 套接字.TCP连接（「${1:127.0.0.1:8080}」，${2:10000}）；", "套接字.发送（流，「${3:问安}」，${2:10000}）；", "定 回应：文 为 套接字.接收（流，${4:65536}，${2:10000}）；", "套接字.关闭（流）；"], "description": "建立带调用级超时和读取上限的 TCP 外连（需 network 权限）" },
  "TCP服务端": { "prefix": "TCP监听", "body": ["引「标准:套接字」为 套接字；", "定 监听器：套接字 为 套接字.TCP监听（「${1:127.0.0.1:9000}」）；", "定 来客：典<文，任意> 为 套接字.接受（监听器，${2:30000}）；", "套接字.关闭（监听器）；"], "description": "监听 TCP 回环地址（包清单须显式 TCP监听 权限）" },
  "UDP套接字": { "prefix": "UDP套接字", "body": ["引「标准:套接字」为 套接字；", "定 数据报：套接字 为 套接字.UDP绑定（「${1:127.0.0.1:0}」）；", "套接字.UDP发送至（数据报，「${2:善哉}」，「${3:127.0.0.1:9000}」，${4:10000}）；", "定 回应：典<文，文> 为 套接字.UDP接收自（数据报，${5:65536}，${4:10000}）；", "套接字.关闭（数据报）；"], "description": "绑定并收发有界 UDP 文字数据报（需 udp_bind 权限，外发另需 network）" },
  "套接字错误": { "prefix": "套接字错误", "body": ["试 则", "    ${1:套接字.TCP连接（地址，10000）；}", "救 ${2:所误} 则", "    言 ${2:所误}.代码；", "    言 ${2:所误}.类别；", "终"], "description": "捕获并判断稳定 SOCKET_* 套接字错误" },
  "字节串": { "prefix": "字节串", "body": ["引「标准:字节」为 字节；", "定 ${1:数据}：字节串 为 字节.从文字（「${2:言序}」）；", "言 字节.长度（${1:数据}）；"], "description": "创建 UTF-8 字节串并按实际字节数计长" },
  "二进制网络请求": { "prefix": "网络字节", "body": ["引「标准:字节」为 字节；", "引「标准:网络」为 网络；", "定 首部：典<文，文> 为 {「Content-Type」：「${1:application/octet-stream}」}；", "定 响应：典<文，任意> 为 网络.请求字节（「${2:POST}」，「${3:https://example.com}」，首部，字节.从文字（「${4}」），${5:10000}，${6:4194304}）；", "定 正文：字节串 为 响应【「正文」】；"], "description": "发送受校验的自定义首部和二进制 HTTP 正文" },
  "TCP字节流": { "prefix": "TCP字节", "body": ["引「标准:套接字」为 套接字；", "引「标准:字节」为 字节；", "定 流：套接字 为 套接字.TCP连接（「${1:127.0.0.1:8080}」，${2:10000}）；", "套接字.TCP无延迟（流，真）；", "套接字.发送字节（流，字节.从文字（「${3:问安}」），${2:10000}）；", "定 所得：典<文，任意> 为 套接字.接收字节（流，${4:65536}，${2:10000}）；", "套接字.关闭写端（流）；", "套接字.关闭（流）；"], "description": "收发带 EOF 语义的 TCP 二进制数据" }
}
