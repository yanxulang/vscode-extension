{
  "变量声明": { "prefix": "令", "body": ["令 ${1:名称}${2:：任意} 为 ${3:值}；"], "description": "声明言序变量" },
  "不可改写绑定": { "prefix": "定", "body": ["定 ${1:名称}${2:：任意} 为 ${3:值}；"], "description": "声明不可改写绑定" },
  "输出": { "prefix": "言", "body": ["言 ${1:值}；"], "description": "输出一个值" },
  "判断": { "prefix": "若", "body": ["若 ${1:条件} 则", "    ${2}", "否则", "    ${3}", "终"], "description": "若/否则判断" },
  "循环": { "prefix": "当", "body": ["当 ${1:条件} 则", "    ${2}", "终"], "description": "当循环" },
  "迭代": { "prefix": "逐", "body": ["逐 ${1:项目}${2:：任意} 于 ${3:容器} 则", "    ${4}", "终"], "description": "迭代列、元组、文字或典" },
  "元组": { "prefix": "元", "body": ["（${1:甲}，${2:乙}）"], "description": "创建不可变元组" },
  "切片": { "prefix": "切片", "body": ["${1:容器}【${2:起}：${3:止}】"], "description": "取得列、元组或文字的半开切片" },
  "捕获错误": { "prefix": "试", "body": ["试 则", "    ${1}", "救 ${2:所误} 则", "    ${3}", "终"], "description": "捕获结构化运行错误" },
  "函数": { "prefix": "法", "body": ["法 ${1:名称}（${2:参数：任意}）${3:：任意} 则", "    ${4}", "终"], "description": "定义函数" },
  "异步函数": { "prefix": "异法", "body": ["异 法 ${1:名称}（${2:参数：任意}）${3:：任意} 则", "    ${4}", "终"], "description": "定义返回任务的异步函数" },
  "等待任务": { "prefix": "候", "body": ["候 ${1:任务}"], "description": "等待任务并取得其结果" },
  "结构化等待": { "prefix": "并候", "body": ["并候（【${1:任务甲}，${2:任务乙}】）"], "description": "在结构化作用域等待一组任务" },
  "类": { "prefix": "类", "body": ["类 ${1:名称} 则", "    公 域 ${2:字段}：${3:任意}；", "    法 初始化（${2:字段}：${3:任意}）则", "        置 此.${2:字段} 为 ${2:字段}；", "    终", "$0", "终"], "description": "定义类、字段与初始化方法" },
  "结构协议": { "prefix": "协", "body": ["协 ${1:名称} 则", "    域 ${2:字段}：${3:任意}；", "    法 ${4:方法}（${5}）：${6:任意}；", "终"], "description": "定义结构协议" },
  "纳入协议": { "prefix": "纳", "body": ["类 ${1:名称} 纳 ${2:协议} 则", "    ${3}", "终"], "description": "定义显式纳入协议的类" },
  "声明字段": { "prefix": "域", "body": ["${1:公} ${2:只} 域 ${3:名称}：${4:任意}${5: 为 值}；"], "description": "声明实例或静态字段" },
  "公开函数": { "prefix": "公法", "body": ["公 法 ${1:名称}（${2:参数：任意}）${3:：任意} 则", "    ${4}", "终"], "description": "定义模块公开函数" },
  "继承类": { "prefix": "承", "body": ["类 ${1:子类} 承 ${2:父类} 则", "    ${3}", "终"], "description": "定义单继承子类" },
  "联合类型": { "prefix": "联合", "body": ["${1:数}|${2:文}"], "description": "创建联合类型标注" },
  "可空类型": { "prefix": "可空", "body": ["${1:数}?"], "description": "创建可空类型标注" },
  "泛型列表": { "prefix": "列型", "body": ["列<${1:数}>"], "description": "创建带元素类型的列标注" },
  "泛型字典": { "prefix": "典型", "body": ["典<${1:文}，${2:数}>"], "description": "创建带键值类型的典标注" },
  "任务类型": { "prefix": "任务型", "body": ["任务<${1:数}>"], "description": "创建任务结果类型标注" },
  "导入模块": { "prefix": "引", "body": ["引「${1:路径.yx}」为 ${2:模块名}；"], "description": "导入文件模块" },
  "导入标准库": { "prefix": "引标准", "body": ["引「标准:${1|文字,数学,时间,文件,JSON,网络,测试,路径,环境,哈希,编码,统计,CSV,随机,标识,模板,校验,Base64,正则,URL,日期|}」为 ${2:模块}；"], "description": "从 21 个标准模块中选择并导入" },
  "Base64往返": { "prefix": "Base64", "body": ["引「标准:Base64」为 Base64；", "定 编码值：文 为 Base64.编码（${1:原文}）；", "定 原文：文 为 Base64.解码（编码值）；"], "description": "使用言序 1.1 Base64 模块编解码 UTF-8 文字" },
  "正则匹配": { "prefix": "正则", "body": ["引「标准:正则」为 正则；", "定 匹配项：文? 为 正则.首项（「${1:[0-9]+}」，${2:文字}）；"], "description": "使用言序 1.1 正则模块查找首个匹配项" },
  "URL解析": { "prefix": "URL", "body": ["引「标准:URL」为 URL；", "定 主机：文? 为 URL.主机（${1:地址}）；", "定 路径：文 为 URL.路径（${1:地址}）；"], "description": "使用言序 1.1 URL 模块解析地址" },
  "日期运算": { "prefix": "日期", "body": ["引「标准:日期」为 日期；", "定 新日期：文 为 日期.加天（「${1:2026-07-14}」，${2:30}）；"], "description": "使用言序 1.1 日期模块进行确定性公历运算" }
}
